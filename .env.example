# PostgreSQL bağlantı sətri (Railway "Variables" bölməsindən gəlir)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# NextAuth üçün təsadüfi, məxfi açar (məs: openssl rand -base64 32)
NEXTAUTH_SECRET="dəyişdirin-bu-təsadüfi-uzun-mətn-olmalıdır"

# Tətbiqin canlı ünvanı (Railway domeni)
NEXTAUTH_URL="https://sizin-domain.up.railway.app"
